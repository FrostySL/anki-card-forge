# Generierte Anki-Pakete (reproduzierbar aus den .cards.json)
decks/*.apkg

# Gerenderte Vorschau-PNGs (reproduzierbar via tools/preview.sh)
decks/preview/

# Python
__pycache__/
*.py[cod]

# OS / Editor
.DS_Store
Thumbs.db
*.swp

# Quelldateien (eigene PDFs/Bücher, oft persönlich/groß) NICHT versionieren.
# Nur der Ordner bleibt erhalten. Willst du eine bestimmte Quelle doch tracken:
#   git add -f quellen/dateiname.pdf
quellen/*
!quellen/.gitkeep
