# Generierte Anki-Pakete (reproduzierbar aus den .cards.json) – auch in Themen-Unterordnern
decks/*.apkg
decks/**/*.apkg

# Gerenderte Vorschau-PNGs (reproduzierbar via tools/preview.sh) – auch verschachtelt
decks/preview/
decks/**/preview/

# Eigene Karten-JSONs (aus persönlichen Quellen) bleiben lokal – nur das generische
# Beispiel-Deck wird versioniert. Eine bestimmte doch tracken: git add -f <pfad>
decks/**/*.cards.json
!decks/beispiel.cards.json

# Python
__pycache__/
*.py[cod]

# OS / Editor
.DS_Store
Thumbs.db
*.swp

# Quelldateien (eigene PDFs/Bücher, oft persönlich/groß) NICHT versionieren.
# Nur der Ordner bleibt erhalten. Willst du eine bestimmte Quelle doch tracken:
#   git add -f quellen/dateiname.pdf
quellen/*
!quellen/.gitkeep

# Aus den (persönlichen) Quellen abgeleitete Markdown-Extrakte (reproduzierbar
# via tools/extract.sh) NICHT versionieren.
aufbereitet/

# Nachschlagewerke (Ankis Quellcode = AGPL-3.0, Anki-Handbuch) NICHT versionieren –
# fremder Code/Lizenz. Lokal vorhalten; Anleitung in reference/README.md.
reference/*
!reference/README.md
