# Generierte Anki-Pakete (reproduzierbar aus den .cards.json) – auch in Themen-Unterordnern
decks/*.apkg
decks/**/*.apkg

# Gerenderte Vorschau-PNGs (reproduzierbar via tools/preview.sh) – auch verschachtelt
decks/preview/
decks/**/preview/

# Aus persönlichen Quellen abgeleitete Karten, die nicht ins Repo sollen
decks/EWP/03_Arbeitstechniken.cards.json

# Python
__pycache__/
*.py[cod]

# OS / Editor
.DS_Store
Thumbs.db
*.swp

# Quelldateien (eigene PDFs/Bücher, oft persönlich/groß) NICHT versionieren.
# Nur der Ordner bleibt erhalten. Willst du eine bestimmte Quelle doch tracken:
#   git add -f quellen/dateiname.pdf
quellen/*
!quellen/.gitkeep

# Aus den (persönlichen) Quellen abgeleitete Markdown-Extrakte (reproduzierbar
# via tools/extract.sh) NICHT versionieren.
aufbereitet/
